# Google AI — required for ADK / Gemini (not needed if mock_agents is true)
GOOGLE_API_KEY=your-google-api-key-here

# Mock agents — deterministic responses, no LLM calls (great for frontend dev)
PARAKEET_MOCK_AGENTS=true

